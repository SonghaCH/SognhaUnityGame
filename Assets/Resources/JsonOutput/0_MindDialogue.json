    "BGImagePath": "Sprite/CU work",
    "SelectionDialogueIdList": null,
    "TexturePath": null,
    "VoicePath": null,
    "CharacterDataId": null
  },
  {
    "Id": "mindDialogue_Opening_1_1_199",
    "Description": "하지만 알바를 하는 와중에도 그녀는 마음속에 비집고 들어왔고",
